# Copy to web/.env.local for local dev. Use the same Neon connection string as
# the root .env (DATABASE_URL). Never commit .env.local; it is gitignored.
DATABASE_URL=

# Canonical site origin for absolute metadata URLs (Open Graph, canonical,
# sitemap). Leave blank for local dev (falls back to VERCEL_URL, then
# http://localhost:3000). Set this on a real deploy, e.g. https://reliquery.app
NEXT_PUBLIC_SITE_URL=

# Visual search (/identify). The embedding worker the query route calls (URL ends
# in /embed) and its bearer token; the same values are in the root .env.
EMBED_ENDPOINT_URL=
EMBED_AUTH_TOKEN=

# Vercel Blob. BLOB_READ_WRITE_TOKEN is added automatically when the store is
# connected to the project. BLOB_PUBLIC_HOST optionally pins the fetch guard to
# this store's exact public host (e.g. abcd1234.public.blob.vercel-storage.com);
# leave blank to allow any Vercel Blob host. CRON_SECRET protects the daily
# sweep that deletes any orphaned query image.
BLOB_READ_WRITE_TOKEN=
BLOB_PUBLIC_HOST=
CRON_SECRET=
